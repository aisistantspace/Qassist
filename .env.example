# Supabase (get anon + service_role keys from Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://eqiurktrdkojnhbxqjge.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-from-dashboard
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-from-dashboard

# OpenAI
OPENAI_API_KEY=sk-your-api-key

# Mailchimp
MAILCHIMP_API_KEY=your-api-key
MAILCHIMP_SERVER_PREFIX=us21
MAILCHIMP_AUDIENCE_ID=your-audience-id

# HubSpot
HUBSPOT_ACCESS_TOKEN=your-access-token

# LLM Providers (optional - configure in dashboard or here)
# GROQ_API_KEY=gsk_your-groq-key
# TOGETHER_API_KEY=your-together-key
# OPENROUTER_API_KEY=sk-or-v1-your-openrouter-key

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_WHATSAPP_NUMBER=59995215195

# Papiamentu self-learning (optional, default off)
# When true, corrections made by the Papiamentu layer are logged to papiamentu_corrections for review
# PAPIAMENTU_LEARNING_ENABLED=false

# Dashboard Authentication
# Password required to access the dashboard at /dashboard
# Set a strong password and keep it secure
DASHBOARD_PASSWORD=your-secure-password-here

# WhatsApp Business API (configured via dashboard at /dashboard/settings)
# These are stored in Supabase, not environment variables
# But you can reference them here for documentation purposes

# Email Notifications (for internal notifications to admin)
# Priority: Resend > SendGrid > SMTP > Log
ADMIN_EMAIL=admin@example.com
FROM_EMAIL=noreply@livinginparadise.nl

# Resend (optional - for transactional emails)
# RESEND_API_KEY=re_xxxxxxxxxxxxx

# SendGrid (optional - for transactional emails)
# SENDGRID_API_KEY=SG.xxxxxxxxxxxxx

# SMTP (for internal notifications via your email server)
SMTP_HOST=smtp.yourdomain.com
SMTP_PORT=587
SMTP_USER=your-email@yourdomain.com
SMTP_PASSWORD=your-email-password
SMTP_FROM_EMAIL=noreply@yourdomain.com
SMTP_SECURE=false


